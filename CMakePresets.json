{
  "version": 3,
  "configurePresets": [
    {
      "name": "vs-debug",
      "displayName": "Visual Studio Debug",
      "binaryDir": "${sourceDir}/build/vs-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "D:/libraries/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "vs-release",
      "displayName": "Visual Studio Release",
      "binaryDir": "${sourceDir}/build/vs-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "D:/libraries/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "vs-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-release",
      "configurePreset": "vs-release",
      "configuration": "Release"
    }
  ]
}